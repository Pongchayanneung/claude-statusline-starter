{
  "_pick_one_statusLine_block_below": "Merge the matching block into ~/.claude/settings.json",

  "statusLine_python_windows": {
    "type": "command",
    "command": "py \"%USERPROFILE%\\.claude\\statusline.py\"",
    "padding": 0
  },

  "statusLine_python_unix": {
    "type": "command",
    "command": "python3 ~/.claude/statusline.py",
    "padding": 0
  },

  "statusLine_powershell_windows": {
    "type": "command",
    "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"%USERPROFILE%\\.claude\\statusline.ps1\"",
    "padding": 0
  },

  "statusLine_bash_unix": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh",
    "padding": 0
  }
}
